# Kopie nach .env oder config/secrets.env im Projektroot (beide git-ignoriert).
# Keine echten Keys hier committen.

# Optional — BigQuery / GKG (sonst gcloud application-default login + ADC-Datei)
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
# GOOGLE_CLOUD_PROJECT=gedelt-calls

GEMINI_API_KEY=
# Optional: GEMINI_MODEL=models/gemini-2.5-flash
# Optional: GEMINI_NO_SEARCH=1 — Gemini-Analyse ohne Google-Search-Tool (weniger API-Fehler)
